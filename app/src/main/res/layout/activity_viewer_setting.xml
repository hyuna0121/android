<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="뷰어 맞춤 설정"
            android:textColor="#333333"
            android:textSize="24sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="24dp"
            android:background="@android:color/white"
            android:elevation="2dp"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="설정하신 환경이 이렇게 적용됩니다.\n편안한 독서를 위한 맞춤 설정입니다."
                android:textColor="#000000" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="배경색 테마"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <Button
                android:id="@+id/btn_theme_white"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:backgroundTint="#F5F5F5"
                android:text="기본"
                android:textColor="#333333" />

            <Button
                android:id="@+id/btn_theme_light_gray"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:backgroundTint="#E0E0E0"
                android:text="그레이"
                android:textColor="#000000" />

            <Button
                android:id="@+id/btn_theme_dark_gray"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:backgroundTint="#424242"
                android:text="다크그레이"
                android:textColor="#E0E0E0" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <Button
                android:id="@+id/btn_theme_black"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:backgroundTint="#000000"
                android:text="블랙"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_theme_beige"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:backgroundTint="#F6F1E5"
                android:text="베이지"
                android:textColor="#4E3726" />

            <Button
                android:id="@+id/btn_theme_green"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:backgroundTint="#233E3B"
                android:text="다크그린"
                android:textColor="#BDD9B9" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="글꼴"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rg_font_family"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rb_font_default"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="시스템" />

            <RadioButton
                android:id="@+id/rb_font_nanum_barun"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="나눔바른고딕" />

            <RadioButton
                android:id="@+id/rb_font_nanum_round"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="나눔스퀘어라운드" />

            <RadioButton
                android:id="@+id/rb_font_ridi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="리디바탕" />

            <RadioButton
                android:id="@+id/rb_font_kopub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="KoPub 바탕" />

            <RadioButton
                android:id="@+id/rb_font_maru"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="마루부리" />
        </RadioGroup>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="글자 굵게 보기"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_font_size_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="글자 크기 (18sp)"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/sb_font_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:max="30" />

        <TextView
            android:id="@+id/tv_line_spacing_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="줄 간격 (1.5x)"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/sb_line_spacing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:max="20" />

        <TextView
            android:id="@+id/tv_letter_spacing_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="자간 넓게 (0.0)"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/sb_letter_spacing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:max="15" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btn_save_settings"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:backgroundTint="#007AFF"
            android:text="설정 저장"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>