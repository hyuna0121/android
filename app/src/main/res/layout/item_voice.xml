<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="20dp"
    android:paddingEnd="16dp"
    android:background="?attr/selectableItemBackground"
    tools:ignore="HardcodedText,ContentDescription"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- AI 뱃지 -->
    <TextView
        android:id="@+id/tv_ai_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI"
        android:textSize="10sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/bg_rounded_purple"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_marginEnd="10dp"
        android:visibility="gone" />

    <!-- 이름 + 태그 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_voice_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#111111" />

        <TextView
            android:id="@+id/tv_voice_tags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ic_check_on / ic_check_off 기반 선택 표시 -->
    <ImageView
        android:id="@+id/iv_voice_check"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_check_off"
        android:visibility="gone" />

</LinearLayout>