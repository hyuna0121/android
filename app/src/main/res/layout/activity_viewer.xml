<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:ignore="HardcodedText,ContentDescription"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 상단 바 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:drawablePadding="6dp"
            android:gravity="center_vertical"
            android:text="뒤로 가기"
            android:textColor="#6C5CE7"
            android:textSize="15sp"
            app:drawableStartCompat="@android:drawable/ic_menu_revert"
            app:drawableTint="#6C5CE7"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tv_viewer_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="스캔 결과"
            android:textColor="#111111"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── 기본 하단 바 ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 듣기 버튼 (왼쪽) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/btn_tts_play"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_media_play"
                android:background="@drawable/bg_rounded_purple"
                android:padding="11dp"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="듣기"
                android:textSize="10sp"
                android:textColor="#6C5CE7"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- 페이지 번호 (중앙) -->
        <TextView
            android:id="@+id/tv_page_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="1 / 1"
            android:textSize="12sp"
            android:textColor="#AAAAAA" />

        <!-- 보기 설정 버튼 (오른쪽) -->
        <LinearLayout
            android:id="@+id/btn_viewer_setting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:background="@drawable/bg_rounded_purple_ghost"
                android:padding="11dp"
                app:tint="#6C5CE7" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="보기 설정"
                android:textSize="10sp"
                android:textColor="#6C5CE7"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── TTS 플레이어 시트 ─────────────────────────────────────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tts_player_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:elevation="8dp"
        android:visibility="gone"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 듣기 종료 -->
        <TextView
            android:id="@+id/btn_tts_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="듣기 종료"
            android:textColor="#6C5CE7"
            android:textSize="14sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 책 제목 (중앙) -->
        <TextView
            android:id="@+id/tv_tts_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_tts_close"
            app:layout_constraintEnd_toStartOf="@id/tv_tts_page" />

        <!-- 페이지 번호 (우측) -->
        <TextView
            android:id="@+id/tv_tts_page"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 1"
            android:textColor="#888888"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 구분선 -->
        <View
            android:id="@+id/tts_divider"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#444444"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 음성 선택 -->
        <LinearLayout
            android:id="@+id/btn_voice_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/tts_divider"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tv_current_voice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Android TTS"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ›"
                android:textColor="#AAAAAA"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- 속도 -->
        <LinearLayout
            android:id="@+id/btn_speed_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/tts_divider"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_tts_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0x"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ∨"
                android:textColor="#AAAAAA"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- 재생 컨트롤 -->
        <ImageButton
            android:id="@+id/btn_tts_prev"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btn_voice_select"
            app:layout_constraintEnd_toStartOf="@id/btn_tts_play_sheet"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btn_tts_play_sheet"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/ic_media_play"
            android:background="@drawable/bg_rounded_purple"
            android:padding="14dp"
            app:tint="#FFFFFF"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btn_voice_select"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btn_tts_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_next"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btn_voice_select"
            app:layout_constraintStart_toEndOf="@id/btn_tts_play_sheet"
            android:layout_marginStart="16dp"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── 로딩 오버레이 (음성 생성 중) ────────────────────────────────── -->
    <!-- 기본 모드: 기존 하단바 + 로딩 -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="gone"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminate="true"
            android:indeterminateTint="#6C5CE7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="음성 생성 중..."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>