<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="회원가입"
        android:textColor="#333333"
        android:textSize="28sp"
        android:textStyle="bold" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_signup_email"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@android:drawable/editbox_background_normal"
            android:hint="이메일 (예: test@email.com)"
            android:inputType="textEmailAddress"
            android:paddingStart="12dp" />

        <Button
            android:id="@+id/btn_check_email"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:text="중복확인" />
    </LinearLayout>

    <EditText
        android:id="@+id/et_signup_password"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/editbox_background_normal"
        android:hint="비밀번호 (영문, 숫자 조합 8자 이상)"
        android:inputType="textPassword"
        android:paddingStart="12dp" />

    <EditText
        android:id="@+id/et_signup_dob"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="생년월일 8자리 (YYYYMMDD)"
        android:inputType="number"
        android:maxLength="8"
        android:background="@android:drawable/editbox_background_normal"
        android:paddingStart="12dp"
        android:layout_marginBottom="16dp" />

    <CheckBox
        android:id="@+id/cb_dyslexia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="난독증 등 글을 읽는 데 어려움이 있습니다."
        android:textColor="#333333"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btn_signup_submit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:backgroundTint="#007AFF"
        android:text="가입 완료"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>