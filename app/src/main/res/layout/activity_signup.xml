<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- ── 로고 영역 (로그인과 동일) ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <androidx.cardview.widget.CardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EDE9FE">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="H"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#6C5CE7"
                    android:gravity="center" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="H-Book"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#6C5CE7"
                android:fontFamily="@font/hbook_font"
                android:letterSpacing="-0.02" />

        </LinearLayout>

        <!-- ── 입력 폼 ──────────────────────────────────────────────────────── -->

        <!-- 이메일 + 중복확인 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/et_signup_email"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="이메일"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:textColor="#222222"
                android:textColorHint="#BBBBBB" />

            <Button
                android:id="@+id/btn_check_email"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:text="중복확인"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/bg_button_secondary"
                android:stateListAnimator="@null"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

        </LinearLayout>

        <!-- 비밀번호 -->
        <EditText
            android:id="@+id/et_signup_password"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="비밀번호 (영문·숫자 조합 8자 이상)"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:textColor="#222222"
            android:textColorHint="#BBBBBB"
            android:layout_marginBottom="12dp" />

        <!-- 생년월일 -->
        <EditText
            android:id="@+id/et_signup_dob"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="생년월일 8자리 (YYYYMMDD)"
            android:inputType="number"
            android:maxLength="8"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:textColor="#222222"
            android:textColorHint="#BBBBBB"
            android:layout_marginBottom="16dp" />

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E0DCFF"
            android:layout_marginBottom="14dp" />

        <!-- 난독증 커스텀 체크 행 -->
        <LinearLayout
            android:id="@+id/layout_dyslexia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/iv_dyslexia_check"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_check_off" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="난독증 등 글을 읽는 데 어려움이 있습니다."
                android:textColor="#555555"
                android:textSize="13sp" />

            <!-- 숨겨진 CheckBox — 값 보관용 -->
            <CheckBox
                android:id="@+id/cb_dyslexia"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 가입 완료 버튼 -->
        <Button
            android:id="@+id/btn_signup_submit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="가입 완료"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_main"
            android:stateListAnimator="@null"
            android:layout_marginBottom="8dp" />

        <!-- 로딩 -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:indeterminateTint="#6C5CE7"
            android:visibility="gone" />

        <!-- 로그인 링크 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이미 계정이 있으신가요?  "
                android:textColor="#AAAAAA"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_go_to_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="로그인"
                android:textColor="#6C5CE7"
                android:textSize="13sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>