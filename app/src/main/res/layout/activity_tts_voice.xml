<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹ 뒤로"
            android:textSize="16sp"
            android:textColor="#007AFF"
            android:paddingEnd="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TTS 음성 선택"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:gravity="center"/>

        <!-- 오른쪽 여백 맞춤용 빈 공간 -->
        <View
            android:layout_width="48dp"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- 음성 선택 카드 목록 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/btn_save">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="낭독 음성을 선택하세요"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginBottom="16dp"/>

            <!-- Cherry -->
            <LinearLayout
                android:id="@+id/card_cherry"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/voice_card_bg"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cherry"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="여성 · 밝고 따뜻한 톤"
                        android:textSize="13sp"
                        android:textColor="#888888"/>

                </LinearLayout>

                <RadioButton
                    android:id="@+id/rb_cherry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#007AFF"/>

            </LinearLayout>

            <!-- Serena -->
            <LinearLayout
                android:id="@+id/card_serena"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/voice_card_bg"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Serena"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="여성 · 차분하고 성숙한 톤"
                        android:textSize="13sp"
                        android:textColor="#888888"/>

                </LinearLayout>

                <RadioButton
                    android:id="@+id/rb_serena"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#007AFF"/>

            </LinearLayout>

            <!-- Ethan -->
            <LinearLayout
                android:id="@+id/card_ethan"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/voice_card_bg"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ethan"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="남성 · 안정적이고 신뢰감 있는 톤"
                        android:textSize="13sp"
                        android:textColor="#888888"/>

                </LinearLayout>

                <RadioButton
                    android:id="@+id/rb_ethan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#007AFF"/>

            </LinearLayout>

            <!-- Chelsie -->
            <LinearLayout
                android:id="@+id/card_chelsie"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/voice_card_bg"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chelsie"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="여성 · 활기차고 에너지 있는 톤"
                        android:textSize="13sp"
                        android:textColor="#888888"/>

                </LinearLayout>

                <RadioButton
                    android:id="@+id/rb_chelsie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#007AFF"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 저장 버튼 -->
    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:text="저장"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#007AFF"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>